{
  "# Section Comment": {
    "body": "-- =============================================\n-- ========== ${1:Section Comment}\n-- =============================================$0",
    "prefix": "seccom"
  },
  "# Section Separator": {
    "body": "-- ==================== ${1:Section Separator} ====================$0",
    "prefix": "secsep"
  },
  "# Subsection Comment": {
    "body": [
      "-- -----------------------------------",
      "-- -------- ${1:Subsection Comment}",
      "-- -----------------------------------$0"
    ],
    "prefix": "subseccom"
  },
  "# Subsection Separator": {
    "body": "-- ---------- ${1:Subsection Separator}$0",
    "prefix": "subsecsep"
  }
}
