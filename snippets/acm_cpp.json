  "# Segment Tree": {
    "body": [
      "/* Segment Tree Template */",
      "struct SEG {",
      "\tstruct node {",
      "\t\tint l, r;",
      "\t\tint val;",
      "\t\tint lazy;",
      "\t}t[N << 2];",
      "\tstatic void pushdown(node& op, int lazy) {",
      "\t\top.val += (op.r - op.l + 1) * lazy;",
      "\t\top.lazy += lazy;",
      "\t}",
      "\tvoid pushdown(int x) {",
      "\t\tif (!t[x].lazy) return;",
      "\t\tpushdown(t[x << 1], t[x].lazy), pushdown(t[x << 1 | 1], t[x].lazy);",
      "\t\tt[x].lazy = 0;",
      "\t}",
      "\tstatic void pushup(node& p, node& l, node& r) {",
      "\t\tp.val = l.val + r.val;",
      "\t}",
      "\tvoid pushup(int x) { pushup(t[x], t[x << 1], t[x << 1 | 1]); }",
      "\tvoid build(int l, int r, int x = 1) {",
      "\t\tt[x] = { l, r, 0, 0 };",
      "\t\tif (l == r) return;",
      "\t\tint mid = l + r >> 1;",
      "\t\tbuild(l, mid, x << 1), build(mid + 1, r, x << 1 | 1);",
      "\t\tpushup(x);",
      "\t}",
      "\tvoid modify(int l, int r, int c, int x = 1) {",
      "\t\tif (l <= t[x].l and r >= t[x].r) {",
      "\t\t\tpushdown(t[x], c);",
      "\t\t\treturn;",
      "\t\t}",
      "\t\tpushdown(x);",
      "\t\tint mid = t[x].l + t[x].r >> 1;",
      "\t\tif (l <= mid) modify(l, r, c, x << 1);",
      "\t\tif (r > mid) modify(l, r, c, x << 1 | 1);",
      "\t\tpushup(x);",
      "\t}",
      "\tint ask(int l, int r, int x = 1) {",
      "\t\tif (l <= t[x].l and r >= t[x].r) return t[x].val;",
      "\t\tpushdown(x);",
      "\t\tint mid = t[x].l + t[x].r >> 1;",
      "\t\tint res = 0;",
      "\t\tif (l <= mid) res = ask(l, r, x << 1);",
      "\t\tif (r > mid) res += ask(l, r, x << 1 | 1);",
      "\t\treturn res;",
      "\t}",
      "}seg;"
    ],
    "prefix": "seg"
  },
