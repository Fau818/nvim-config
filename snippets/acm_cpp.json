      "/* Disjoint Set Union Template */",
      "struct DSU {",
      "\tint p[N];",
      "\tint find(int x) { return x == p[x] ? x : p[x] = find(p[x]); }",
      "\tvoid merge(int a, int b) {",
      "\t\ta = find(a), b = find(b);",
      "\t\tif (a == b) return;",
      "\t\tp[b] = a;",
      "\t}",
      "\tvoid init(int n) { rep(i, n) p[i] = i; }",
      "}dsu;"
