  "# Dynamic HJT Tree": {
    "body": [
      "/* 动态主席树模版 */",
      "const int L = 1; int R = N - 5;",
      "int rt[N], root[N];  // root是动态树, rt是静态树",
      "struct CRT {",
      "\tstruct node {",
      "\t\tint l, r;",
      "\t\tint val;",
      "\t}t[N * 18 * 18];",
      "\tint ind;  // 多组记得清空",
      "\tint build(int a, int c, int tl, int tr, int p) {  // 静态树建立",
      "\t\tint x = ++ind; t[x] = t[p];",
      "\t\tt[x].val += c;",
      "\t\tif (tl == tr) return x;",
      "\t\tint mid = tl + tr >> 1;",
      "\t\tif (a <= mid) t[x].l = build(a, c, tl, mid, t[p].l);",
      "\t\telse t[x].r = build(a, c, mid + 1, tr, t[p].r);",
      "\t\treturn x;",
      "\t}",
      "\tvoid modify(int a, int c, int tl, int tr, int& x) {  // 修改动态树",
      "\t\tif (!x) x = ++ind;",
      "\t\tt[x].val += c;",
      "\t\tif (tl == tr) return;",
      "\t\tint mid = tl + tr >> 1;",
      "\t\ta <= mid ? modify(a, c, tl, mid, t[x].l) : modify(a, c, mid + 1, tr, t[x].r);",
      "\t}",
      "\tint ask(int k, int tl, int tr, vector<int>& p, vector<int>& x) {  // 查询树中第k小",
      "\t\tif (tl == tr) return tl;",
      "\t\tint cou = 0;",
      "\t\tfor (auto& op : x) cou += t[t[op].l].val;",
      "\t\tfor (auto& op : p) cou -= t[t[op].l].val;",
      "\t\tint mid = tl + tr >> 1;",
      "\t\tvector<int> np, nx;",
      "\t\tif (cou >= k) {",
      "\t\t\tfor (auto& op : p) np.push_back(t[op].l);",
      "\t\t\tfor (auto& op : x) nx.push_back(t[op].l);",
      "\t\t\treturn ask(k, tl, mid, np, nx);",
      "\t\t}",
      "\t\tfor (auto& op : p) np.push_back(t[op].r);",
      "\t\tfor (auto& op : x) nx.push_back(t[op].r);",
      "\t\treturn ask(k - cou, mid + 1, tr, np, nx);  // 记得减去左边贡献",
      "\t}",
      "}crt;",
      "struct BIT {",
      "\tstatic int lowbit(int x) { return x & -x; }",
      "\tvoid add(int x, int a, int c) { for (int i = x; i <= n; i += lowbit(i)) crt.modify(a, c, L, R, root[i]); }",
      "\tint ask(int l, int r, int k) {",
      "\t\tvector<int> nx(1, rt[r]), np(1, rt[l - 1]);  // 别忘了推入静态树",
      "\t\tfor (int i = r; i; i -= lowbit(i)) nx.push_back(root[i]);",
      "\t\tfor (int i = l - 1; i; i -= lowbit(i)) np.push_back(root[i]);",
      "\t\treturn crt.ask(k, L, R, np, nx);",
      "\t}",
      "}bit;"
    ],
    "prefix": "dynamic_crt"
  },
  "# Get LCA (Binary lifting) Template": {
    "body": [
      "/* 倍增求LCA模版 */",
      "namespace LCA {",
      "\tconst int B = 17;  // 记录真实的B, f数组多开1即可",
      "\tint dep[N], f[N][B + 1];",
      "\tvoid dfs(int x = 1, int fa = 0) {",
      "\t\tdep[x] = dep[fa] + 1;",
      "\t\tf[x][0] = fa;",
      "\t\trep(i, B) f[x][i] = f[f[x][i - 1]][i - 1];",
      "\t\tfor (auto& to : edge[x]) if (to != fa) dfs(to, x);",
      "\t}",
      "\tint lca(int x, int y) {",
      "\t\tif (dep[x] < dep[y]) swap(x, y);",
      "\t\tfor (int i = B; i >= 0; --i) if (dep[f[x][i]] >= dep[y]) x = f[x][i];",
      "\t\tif (x == y) return x;",
      "\t\tfor (int i = B; i >= 0; --i) if (f[x][i] != f[y][i]) x = f[x][i], y = f[y][i];",
      "\t\treturn f[x][0];",
      "\t}",
      "}"
    ],
    "prefix": "beizenglca"
  },
