  "# Heavy Path Decomposition": {
    "body": [
      "/* 树链剖分求lca模板 */",
      "int p[N], dep[N], sz[N], son[N];",
      "void dfs1(int x = 1, int fa = 0) {",
      "\tp[x] = fa, dep[x] = dep[fa] + 1, sz[x] = 1;  // son[x] = 0;",
      "\tfor (auto& to : edge[x]) {",
      "\t\tif (to == fa) continue;",
      "\t\tdfs1(to, x);",
      "\t\tsz[x] += sz[to];",
      "\t\tif (sz[to] > sz[son[x]]) son[x] = to;",
      "\t}",
      "}",
      "int id[N], top[N], ind;",
      "void dfs2(int x = 1, int tp = 1) {",
      "\tid[x] = ++ind, top[x] = tp;",
      "\tif (!son[x]) return;",
      "\tdfs2(son[x], tp);",
      "\tfor (auto& to : edge[x]) {",
      "\t\tif (to == p[x] or to == son[x]) continue;",
      "\t\tdfs2(to, to);",
      "\t}",
      "}",
      "int lca(int a, int b) {",
      "\twhile (top[a] != top[b]) {",
      "\t\tif (dep[top[a]] < dep[top[b]]) swap(a, b);",
      "\t\ta = p[top[a]];",
      "\t}",
      "\treturn id[a] < id[b] ? a : b;",
      "}"
    ],
    "prefix": "lca"
  },
