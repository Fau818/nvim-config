  "# Combinatorics Template": {
    "body": [
      "/* Combinatorics Template */",
      "int num[N], innum[N];",
      "int fpow(int a, int b) {",
      "\tll res = 1; a %= mod;",
      "\twhile (b) {",
      "\t\tif (b & 1) res = res * a % mod;",
      "\t\tb >>= 1;",
      "\t\ta = 1ll * a * a % mod;",
      "\t}",
      "\treturn res;",
      "}",
      "void init(int n = N - 5)",
      "{",
      "\tnum[0] = innum[0] = 1;",
      "\tfor (int i = 1; i <= n; ++i) {",
      "\t\tnum[i] = 1ll * num[i - 1] * i % mod;",
      "\t}",
      "\tinnum[n] = fpow(num[n], mod - 2);",
      "\tfor (int i = n - 1; i >= 1; --i) {",
      "\t\tinnum[i] = 1ll * innum[i + 1] * (i + 1) % mod;",
      "\t}",
      "}",
      "int C(int a, int b) { return 1ll * num[a] * innum[a - b] % mod * innum[b] % mod; }",
      "int A(int a, int b) { return 1ll * num[a] * innum[a - b] % mod; }"
    ],
    "prefix": "zuheshu"
  },
