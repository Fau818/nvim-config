  "# 01Trie Template": {
    "body": [
      "/* 01Trie Template */",
      "struct TRIE {  // 使用01Trie记得是否需要插入0!!!!!!!!!",
      "\tstatic const int B = 30, M = B * N;",
      "\tint t[M][2]; int ind;",
      "\tint cou[M];  // 统计所有位置的出现情况",
      "\tvoid modify(int c, int val = 1) {  // 添加 / 删除数字",
      "\t\tint x = 0;",
      "\t\tfor (int i = B - 1; i >= 0; --i) {",
      "\t\t\tint w = c >> i & 1;",
      "\t\t\tif (!t[x][w]) t[x][w] = ++ind;",
      "\t\t\tx = t[x][w], cou[x] += val;",
      "\t\t}",
      "\t}",
      "\tint ask(int c) {  // 询问最大异或和",
      "\t\tint x = 0, res = 0;",
      "\t\tfor (int i = B - 1; i >= 0; --i) {",
      "\t\t\tint w = c >> i & 1;",
      "\t\t\tif (cou[t[x][w ^ 1]]) {",
      "\t\t\t\tres += 1 << i;",
      "\t\t\t\tx = t[x][w ^ 1];",
      "\t\t\t}",
      "\t\t\telse x = t[x][w];",
      "\t\t}",
      "\t\treturn res;",
      "\t}",
      "\tvoid clear(int x) {",
      "\t\tcou[x] = 0;",
      "\t\tfor (int i = 0; i < 2; ++i) {",
      "\t\t\tif (t[x][i]) clear(t[x][i]), t[x][i] = 0;",
      "\t\t}",
      "\t}",
      "\tvoid clear() { clear(ind = 0); }",
      "}trie;"
    ],
    "prefix": "01Trie"
  },
